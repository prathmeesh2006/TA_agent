datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String
  name         String?
  role         String     // ADMIN, PROFESSOR, STUDENT
  createdAt    DateTime   @default(now())
  courses      Course[]   @relation("ProfessorCourses")
  exams        Exam[]     @relation("CreatedExams")
  feedbacks    Feedback[] @relation("UserFeedbacks")
}

model Course {
  id          String   @id
  name        String
  code        String   @unique
  professorId String
  professor   User     @relation("ProfessorCourses", fields: [professorId], references: [id], onDelete: Cascade)
  exams       Exam[]
}

model Exam {
  id          String         @id @default(uuid())
  courseId    String
  course      Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title       String
  totalMarks  Int
  durationMin Int
  createdById String
  createdBy   User           @relation("CreatedExams", fields: [createdById], references: [id], onDelete: Cascade)
  status      String         // DRAFT, APPROVED, REJECTED, GENERATING, PAUSED
  createdAt   DateTime       @default(now())
  versions    ExamVersion[]
  agentTasks  AgentTask[]
  feedbacks   Feedback[]
}

model ExamVersion {
  id            String   @id @default(uuid())
  examId        String
  exam          Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  versionNumber Int
  content       String   // JSON string containing exam questions, solutions, and rubric
  createdAt     DateTime @default(now())

  @@unique([examId, versionNumber])
}

model AgentTask {
  id           String   @id @default(uuid())
  examId       String
  exam         Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  agentName    String   // MANAGER, THEORY_WRITER, PROGRAMMER, MATHEMATICIAN, EDITOR
  status       String   // QUEUED, RUNNING, COMPLETED, FAILED
  input        String?  // JSON string of inputs
  output       String?  // JSON string of outputs
  costUsd      Float    @default(0.0)
  tokensUsed   Int      @default(0)
  durationMs   Int      @default(0)
  errorMessage String?
  createdAt    DateTime @default(now())
}

model Feedback {
  id            String   @id @default(uuid())
  examId        String
  exam          Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  versionNumber Int
  comment       String
  createdById   String
  createdBy     User     @relation("UserFeedbacks", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
}
